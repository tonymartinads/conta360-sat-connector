# ─── CONTA360 SAT CONNECTOR ───
# Variables de entorno para el microservicio Node.js externo.
# Desplegar en Railway, Render, Fly.io o VPS.

# Puerto del servidor (Railway/Render lo asignan automaticamente)
PORT=3000

# Shared secret para autenticar requests desde la Edge Function de Supabase.
# DEBE coincidir con SAT_CONNECTOR_SECRET en los Supabase Secrets.
SAT_CONNECTOR_SECRET=conta360-sat-connector-2026